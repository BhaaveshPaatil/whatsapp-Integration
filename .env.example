# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin (server pipeline — required for webhook persistence + AI worker)
# Paste the full service account JSON, or base64-encode it
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional fallback org when phone_number_id is not mapped yet
DEFAULT_ORG_ID=

# Shared secret for /api/workers/process-message
PIPELINE_WORKER_SECRET=change-me-in-production

# Encryption key for storing sensitive tokens (Meta access tokens) in Firestore
# If not set, falls back to PIPELINE_WORKER_SECRET, then a dev default
ENCRYPTION_KEY=

# Gemini AI Integration
GEMINI_API_KEY=your_gemini_api_key

# WhatsApp Business API Config
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_VERIFY_TOKEN=taskflow_verify_token_secret
# Optional: enables X-Hub-Signature-256 verification on inbound webhooks
WHATSAPP_APP_SECRET=
